# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# PyTorch checkpoints (large binaries – push to GCS instead)
checkpoints/*.pth
checkpoints/*.pt
data/

