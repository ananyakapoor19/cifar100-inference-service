results/**/stats_*.csv
results/**/locust.log
results/**/*.html
!results/**/charts/

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# IDE
.vscode/
.idea/
*.swp

# macOS
.DS_Store

# Docker
.dockerignore

# Secrets / credentials
*.json
!infra/**/*.json
!checkpoints/quant_comparison.json
!results/**/charts/*.json
!results/**/summary.json
!checkpoints/gcs_manifest.txt
.env
service-account-key.json

# Claude Code internal
.claude/

